---
layout: base.njk
---
<article class="post-wrap">
  <header class="post-header">
    <p class="breadcrumb"><a href="/">Home</a> / <a href="/communications/news/">News</a></p>
    <h1>{{ title }}</h1>
    <time datetime="{{ date }}">{{ date | readableDate }}</time>
  </header>
  {% if image %}
    <img class="post-image" src="{{ image }}" alt="">
  {% endif %}
  <div class="prose">
    {{ content | safe }}
  </div>
</article>
