<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <link rel="icon" href="/assets/uploads/favicon.png">
    <link rel="stylesheet" href="/assets/css/fonts.css">
    <link rel="stylesheet" href="/assets/css/main.css">
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site-shell">
    <aside class="sidebar-nav" aria-label="Main navigation">
      <a class="sidebar-brand" href="/" aria-label="{{ site.title }}">
        <img src="/assets/uploads/LW-SI-OUTLINED.svg" alt="{{ site.title }}">
      </a>
      <nav class="side-menu">
        {% for item in navigation %}
          {% set childActive = false %}
          {% if item.children %}
            {% for child in item.children %}
              {% if page.url == child.url or page.url.indexOf(child.url) == 0 %}
                {% set childActive = true %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {% set current = page.url == item.url or (item.url != "/" and page.url.indexOf(item.url) == 0) or childActive %}
          <div class="side-menu-item{% if current %} is-open{% endif %}">
            <a href="{{ item.url }}" class="{% if current %}is-active{% endif %}{% if item.children %} has-children{% endif %}"{% if current %} aria-current="page"{% endif %}>{{ item.label }}</a>
            {% if item.children %}
              <div class="side-submenu">
                {% for child in item.children %}
                  {% set childCurrent = page.url == child.url or page.url.indexOf(child.url) == 0 %}
                  <a href="{{ child.url }}" class="{% if childCurrent %}is-active{% endif %}"{% if childCurrent %} aria-current="page"{% endif %}>{{ child.label }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </nav>
    </aside>
    <div class="site-main">
      <header class="site-header">
      <a class="brand" href="/" aria-label="{{ site.title }}">
        <img src="/assets/uploads/LW-SL.png" alt="{{ site.title }}">
      </a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
        <span class="visually-hidden">Toggle navigation</span>
        <span class="menu-toggle-icon" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
      <nav id="site-nav" class="site-nav" aria-label="Main navigation">
        {% for item in navigation %}
          {% set childActive = false %}
          {% if item.children %}
            {% for child in item.children %}
              {% if page.url == child.url or page.url.indexOf(child.url) == 0 %}
                {% set childActive = true %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {% set current = page.url == item.url or (item.url != "/" and page.url.indexOf(item.url) == 0) or childActive %}
          <div class="site-nav-item">
            <a href="{{ item.url }}" class="{% if current %}is-active{% endif %}"{% if current %} aria-current="page"{% endif %}>{{ item.label }}</a>
            {% if item.children %}
              <div class="site-submenu">
                {% for child in item.children %}
                  {% set childCurrent = page.url == child.url or page.url.indexOf(child.url) == 0 %}
                  <a href="{{ child.url }}" class="{% if childCurrent %}is-active{% endif %}"{% if childCurrent %} aria-current="page"{% endif %}>{{ child.label }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </nav>
      </header>
      <main id="main">
      {{ content | safe }}
      </main>
      <footer class="site-footer">
      <div>
        <img src="/assets/uploads/LW-SI-white.svg" alt="{{ site.title }}" class="footer-logo">
      </div>
      <div>
        <h2>LifeWatch Slovenia</h2>
        <a href="/about/">About us</a>
        <a href="/consortium/">Consortium</a>
      </div>
      <div>
        <h2>Contact us</h2>
        <a href="/contacts/">Contacts</a>
      </div>
      <div>
        <h2>Social</h2>
        <a href="{{ site.twitter }}" aria-label="LifeWatch Slovenia on Twitter">
          <svg class="social-icon" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M21.5 6.1c-.7.3-1.4.5-2.2.6.8-.5 1.4-1.2 1.7-2.1-.7.4-1.5.8-2.4.9A3.8 3.8 0 0 0 12 8.1c0 .3 0 .6.1.9a10.8 10.8 0 0 1-7.8-4c-.3.6-.5 1.2-.5 1.9 0 1.3.7 2.5 1.7 3.2-.6 0-1.2-.2-1.7-.5 0 1.9 1.3 3.4 3 3.7-.3.1-.7.1-1 .1-.2 0-.5 0-.7-.1.5 1.5 1.9 2.6 3.5 2.6a7.6 7.6 0 0 1-4.7 1.6H3a10.7 10.7 0 0 0 5.8 1.7c6.9 0 10.7-5.7 10.7-10.7V8c.8-.5 1.4-1.2 2-1.9Z"/>
          </svg>
          <span class="visually-hidden">Twitter</span>
        </a>
      </div>
      </footer>
    </div>
    </div>
    <script src="/assets/js/main.js"></script>
  </body>
</html>
