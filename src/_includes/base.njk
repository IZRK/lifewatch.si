<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title>{{ title or site.title }}</title>
    <meta name="description" content="{{ description or site.description }}">
    <link rel="icon" href="/assets/uploads/favicon.png">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Roboto:ital,wght@0,100..900;1,100..900&amp;family=Roboto+Slab:wght@100..900&amp;family=Titillium+Web:wght@400;600;700&amp;display=swap">
    <link rel="stylesheet" href="/assets/css/main.css">
    {% if page.url != '/' %}<link rel="stylesheet" href="/assets/css/pages.css">{% endif %}
  </head>
  <body>
    <a class="skip-link" href="#main">Skip to content</a>
    <div class="site-shell">
    <aside class="sidebar-nav" aria-label="Main navigation">
      <a class="sidebar-brand" href="/" aria-label="{{ site.title }}">
        <img src="/assets/uploads/LW-SI-OUTLINED.svg" width="785" height="373" loading="eager" decoding="async" alt="{{ site.title }}">
      </a>
      <nav class="side-menu">
        {% for item in navigation %}
          {% set childActive = false %}
          {% if item.children %}
            {% for child in item.children %}
              {% if page.url == child.url or page.url.indexOf(child.url) == 0 %}
                {% set childActive = true %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {% set exactCurrent = page.url == item.url %}
          {% set current = exactCurrent or (item.url != "/" and page.url.indexOf(item.url) == 0) or childActive %}
          <div class="side-menu-item">
            <a href="{{ item.url }}" class="{% if current %}is-active{% endif %}{% if item.children %} has-children{% endif %}"{% if exactCurrent %} aria-current="page"{% endif %}>{{ item.label }}</a>
            {% if item.children %}
              <button class="side-submenu-toggle" type="button" aria-expanded="false" aria-controls="side-submenu-{{ loop.index }}">
                <span class="visually-hidden">Toggle {{ item.label }} submenu</span>
                <span class="side-submenu-toggle-icon" aria-hidden="true">+</span>
              </button>
              <div class="side-submenu" id="side-submenu-{{ loop.index }}">
                {% for child in item.children %}
                  {% set childCurrent = page.url == child.url or page.url.indexOf(child.url) == 0 %}
                  <a href="{{ child.url }}" class="{% if childCurrent %}is-active{% endif %}"{% if childCurrent %} aria-current="page"{% endif %}>{{ child.label }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </nav>
    </aside>
    <div class="site-main">
      <header class="site-header">
      <a class="brand" href="/" aria-label="{{ site.title }}">
        <img src="/assets/uploads/LW-SL.png" width="700" height="300" loading="eager" decoding="async" alt="{{ site.title }}">
      </a>
      <button class="menu-toggle" type="button" aria-expanded="false" aria-controls="site-nav">
        <span class="visually-hidden">Toggle navigation</span>
        <span class="menu-toggle-icon" aria-hidden="true"><span></span><span></span><span></span></span>
      </button>
      <nav id="site-nav" class="site-nav" aria-label="Main navigation">
        {% for item in navigation %}
          {% set childActive = false %}
          {% if item.children %}
            {% for child in item.children %}
              {% if page.url == child.url or page.url.indexOf(child.url) == 0 %}
                {% set childActive = true %}
              {% endif %}
            {% endfor %}
          {% endif %}
          {% set exactCurrent = page.url == item.url %}
          {% set current = exactCurrent or (item.url != "/" and page.url.indexOf(item.url) == 0) or childActive %}
          <div class="site-nav-item">
            <a href="{{ item.url }}" class="{% if current %}is-active{% endif %}"{% if exactCurrent %} aria-current="page"{% endif %}>{{ item.label }}</a>
            {% if item.children %}
              <div class="site-submenu">
                {% for child in item.children %}
                  {% set childCurrent = page.url == child.url or page.url.indexOf(child.url) == 0 %}
                  <a href="{{ child.url }}" class="{% if childCurrent %}is-active{% endif %}"{% if childCurrent %} aria-current="page"{% endif %}>{{ child.label }}</a>
                {% endfor %}
              </div>
            {% endif %}
          </div>
        {% endfor %}
      </nav>
      </header>
      <main id="main">
      {{ content | safe }}
      </main>
      <footer class="site-footer">
      <div class="footer-column footer-brand-column">
        <a class="footer-brand" href="/" aria-label="{{ site.title }} home">
          <img src="/assets/uploads/LW-SI-white.svg" width="785" height="373" alt="" class="footer-logo">
        </a>
      </div>
      <div class="footer-column footer-nav-column">
        <h2>LifeWatch Slovenia</h2>
        <span class="footer-divider" aria-hidden="true"></span>
        <nav class="footer-links" aria-label="LifeWatch Slovenia">
          <a href="/about/">About us</a>
          <a href="/consortium/">Consortium</a>
        </nav>
      </div>
      <div class="footer-column footer-nav-column">
        <h2>Contact us</h2>
        <span class="footer-divider" aria-hidden="true"></span>
        <nav class="footer-links" aria-label="Contact us">
          <a href="/contacts/">Contacts</a>
        </nav>
      </div>
      <div class="footer-column footer-social-column">
        <h2 class="visually-hidden">Social</h2>
        <a class="footer-social-link" href="{{ site.bluesky }}" target="_blank" rel="noopener noreferrer" aria-label="LifeWatch Slovenia on Bluesky">
          <svg class="social-icon" viewBox="0 0 600 530" aria-hidden="true">
            <path d="M135.72 44.03C202.22 93.95 273.74 195.17 300 249.49c26.26-54.32 97.78-155.54 164.28-205.46C512.26 8.01 590-19.86 590 68.83c0 17.71-10.16 148.79-16.11 170.07-20.7 73.98-96.14 92.85-163.25 81.43 117.3 19.96 147.14 86.09 82.7 152.22-122.4 125.59-175.92-31.51-189.63-71.77-2.52-7.38-3.69-10.83-3.69-7.9 0-2.93-1.18.52-3.69 7.9-13.72 40.26-67.24 197.36-189.63 71.77-64.45-66.13-34.61-132.26 82.69-152.22-67.1 11.42-142.55-7.45-163.25-81.43C20.16 217.62 10 86.54 10 68.83 10-19.86 87.74 8.01 135.72 44.03Z"/>
          </svg>
          <span class="visually-hidden">Bluesky</span>
        </a>
      </div>
      </footer>
    </div>
    </div>
    <script src="/assets/js/main.js"></script>
  </body>
</html>
