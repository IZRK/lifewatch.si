---
layout: base.njk
title: News
permalink: /news/
---
<section class="page-hero">
  <p class="breadcrumb"><a href="/">Home</a> / News</p>
  <h1>News & Events</h1>
</section>
<section class="content-wrap">
  <div class="news-list">
    {% for post in posts %}
      <article class="news-row">
        {% if post.image %}<img src="{{ post.image }}" alt="">{% endif %}
        <div>
          <h2><a href="/news/{{ post.slug }}/">{{ post.title | safe }}</a></h2>
          <time datetime="{{ post.date }}">{{ post.date | readableDate }}</time>
          <p>{{ post.excerpt | safe }}</p>
          <a class="read-more" href="/news/{{ post.slug }}/">Read More</a>
        </div>
      </article>
    {% endfor %}
  </div>
</section>
