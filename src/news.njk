---
layout: base.njk
title: News
permalink: /communications/news/
---
<section class="page-titlebar news-titlebar">
  <h1>News</h1>
  <p><a href="/">Home</a> / Communications / News</p>
</section>
<section class="content-wrap news-page" aria-label="News archive">
  <svg class="archive-icon-defs" aria-hidden="true">
    <symbol id="icon-twitter" viewBox="0 0 512 512">
      <path d="M459.4 151.7c.3 4.5.3 9.1.3 13.6 0 138.7-105.6 298.6-298.6 298.6-59.5 0-114.7-17.2-161.1-47.1 8.4 1 16.6 1.3 25.3 1.3 49.1 0 94.2-16.6 130.3-44.8-46.1-1-84.8-31.2-98.1-72.8 6.5 1 13 1.6 19.8 1.6 9.4 0 18.8-1.3 27.6-3.6-48.1-9.7-84.1-52-84.1-103v-1.3c14 7.8 30.2 12.7 47.4 13.3-28.3-18.8-46.8-51-46.8-87.4 0-19.5 5.2-37.4 14.3-53 51.7 63.7 129.3 105.3 216.4 109.8-1.6-7.8-2.6-15.9-2.6-24 0-57.8 46.8-104.9 104.9-104.9 30.2 0 57.5 12.7 76.7 33.1 23.7-4.5 46.5-13.3 66.6-25.3-7.8 24.4-24.4 44.8-46.1 57.8 21.1-2.3 41.6-8.1 60.4-16.2-14.3 20.8-32.2 39.3-52.6 54.3z"/>
    </symbol>
    <symbol id="icon-facebook" viewBox="0 0 320 512">
      <path d="M279.1 288l14.2-92.7h-88.9v-60.1c0-25.4 12.4-50.1 52.2-50.1H297V6.3S260.4 0 225.4 0c-73.2 0-121.1 44.4-121.1 124.7v70.6H22.9V288h81.4v224h100.2V288z"/>
    </symbol>
    <symbol id="icon-linkedin" viewBox="0 0 448 512">
      <path d="M100.3 448H7.4V148.9h92.9zM53.8 108.1C24.1 108.1 0 83.5 0 53.8 0 24.1 24.1 0 53.8 0s53.8 24.1 53.8 53.8c0 29.7-24.1 54.3-53.8 54.3zM447.9 448h-92.7V302.4c0-34.7-.7-79.2-48.3-79.2-48.3 0-55.7 37.7-55.7 76.7V448h-92.8V148.9h89.1v40.8h1.3c12.4-23.5 42.7-48.3 87.9-48.3 94 0 111.3 61.9 111.3 142.3V448z"/>
    </symbol>
  </svg>
  <div class="archive-news-grid">
    {% for post in posts | limit(6) %}
      <article class="archive-card">
        <img class="archive-card-image" src="{{ post.image }}" alt="">
        <div class="archive-card-body">
          <h2><a href="/{{ post.slug }}/">{{ post.title }}</a></h2>
          <p>{{ post.archiveExcerpt }}</p>
          <div class="archive-card-actions">
            <a class="button" href="/{{ post.slug }}/">Read more...</a>
            <div class="share-links" aria-label="Share {{ post.title }}">
              <a href="https://twitter.com/share?url=https://lifewatch.si/{{ post.slug }}/" aria-label="Share on Twitter">
                <svg aria-hidden="true"><use href="#icon-twitter"></use></svg>
              </a>
              <a href="https://www.facebook.com/sharer.php?u=https://lifewatch.si/{{ post.slug }}/" aria-label="Share on Facebook">
                <svg aria-hidden="true"><use href="#icon-facebook"></use></svg>
              </a>
              <a href="https://www.linkedin.com/shareArticle?mini=true&amp;url=https://lifewatch.si/{{ post.slug }}/" aria-label="Share on LinkedIn">
                <svg aria-hidden="true"><use href="#icon-linkedin"></use></svg>
              </a>
            </div>
          </div>
        </div>
      </article>
    {% endfor %}
  </div>
</section>
