<header class="post-detail-heading">
  <h2>5th International SOS Proteus Conference, December 7-8, 2024, Kranj, Slovenia</h2>
</header>
<div class="post-detail-columns">
  <div class="post-detail-media">
    <img width="960" height="537" src="/assets/uploads/WhatsApp-Image-2024-12-19-at-10.36.26.jpeg" alt="Participants at the 5th International SOS Proteus Conference in Kranj" srcset="/assets/uploads/WhatsApp-Image-2024-12-19-at-10.36.26.jpeg 960w, /assets/uploads/WhatsApp-Image-2024-12-19-at-10.36.26-300x168.jpeg 300w, /assets/uploads/WhatsApp-Image-2024-12-19-at-10.36.26-768x430.jpeg 768w" sizes="(max-width: 767px) 100vw, 540px">
